# Copy this file to .env and fill in the values before starting the stack.
#
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis

# ── Langfuse ──────────────────────────────────────────────────────
# Public URL where Langfuse is reachable
LANGFUSE_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
LANGFUSE_NEXTAUTH_SECRET=

# Generate with: openssl rand -base64 32
LANGFUSE_SALT=

# Generate with: openssl rand -hex 32  (must be 64 hex chars, NOT base64)
LANGFUSE_ENCRYPTION_KEY=

# Set after first login — create a project in Langfuse and copy the keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

TELEMETRY_ENABLED=false

# ── LiteLLM ───────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-changeme

# ── n8n ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
N8N_ENCRYPTION_KEY=

N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678
N8N_EXECUTIONS_MODE=regular

# ── LLM provider API keys ─────────────────────────────────────────
OPENAI_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=


# ── Timezone ──────────────────────────────────────────────────────
TZ=UTC
